{
  "name": "@staklyapp/contracts",
  "version": "0.1.0",
  "description": "Stakly v3 lingua franca — Zod schemas + TypeScript types (44C, Display Engine, Apps, Tools, Agents CQRS, Runtime, Errors). Source unique de vérité partagée entre stakly-hub (BFF) et stakly-ui (SPA).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./44c": {
      "import": {
        "types": "./dist/44c/index.d.ts",
        "default": "./dist/44c/index.js"
      },
      "require": {
        "types": "./dist/44c/index.d.cts",
        "default": "./dist/44c/index.cjs"
      }
    },
    "./display-engine": {
      "import": {
        "types": "./dist/display-engine/index.d.ts",
        "default": "./dist/display-engine/index.js"
      },
      "require": {
        "types": "./dist/display-engine/index.d.cts",
        "default": "./dist/display-engine/index.cjs"
      }
    },
    "./apps": {
      "import": {
        "types": "./dist/apps/index.d.ts",
        "default": "./dist/apps/index.js"
      },
      "require": {
        "types": "./dist/apps/index.d.cts",
        "default": "./dist/apps/index.cjs"
      }
    },
    "./tools": {
      "import": {
        "types": "./dist/tools/index.d.ts",
        "default": "./dist/tools/index.js"
      },
      "require": {
        "types": "./dist/tools/index.d.cts",
        "default": "./dist/tools/index.cjs"
      }
    },
    "./agents": {
      "import": {
        "types": "./dist/agents/index.d.ts",
        "default": "./dist/agents/index.js"
      },
      "require": {
        "types": "./dist/agents/index.d.cts",
        "default": "./dist/agents/index.cjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime/index.d.ts",
        "default": "./dist/runtime/index.js"
      },
      "require": {
        "types": "./dist/runtime/index.d.cts",
        "default": "./dist/runtime/index.cjs"
      }
    },
    "./errors": {
      "import": {
        "types": "./dist/errors/index.d.ts",
        "default": "./dist/errors/index.js"
      },
      "require": {
        "types": "./dist/errors/index.d.cts",
        "default": "./dist/errors/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "stakly",
    "contracts",
    "zod",
    "schemas",
    "44c",
    "lingua-franca"
  ],
  "author": "Stakly",
  "license": "UNLICENSED",
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
